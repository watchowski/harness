#!/usr/bin/env python3
"""
Stop hook. Fires at the end of each Claude turn.
Prompts institutional memory capture per Principle 05.
"""
import sys
import json

def main():
    try:
        json.load(sys.stdin)  # consume stdin
    except Exception:
        pass

    message = (
        "INSTITUTIONAL MEMORY CHECK (Principle 05):\n"
        "Did any mistakes, unexpected behaviors, or corrections occur this session?\n"
        "If yes — add an entry to docs/harness/learnings.md:\n"
        "  1. What happened\n"
        "  2. Why it happened\n"
        "  3. How to prevent it in future sessions"
    )

    print(json.dumps({"systemMessage": message}))
    sys.exit(0)

if __name__ == "__main__":
    main()
